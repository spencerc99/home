---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import { marked } from "marked";
import { CreationDetailImages } from "../components/CreationDetailImages";
import "./CreationDetail.scss";
import BaseLayout from "./BaseLayout.astro";
import { ImageOrVideo } from "../components/ImageOrVideo";
import { stringToColor } from "../utils";
import { maybeTransformImgixUrl } from "../utils/images";

type ResolvedRelated = CollectionEntry<"creation">["data"] & { id: string };

type Props = CollectionEntry<"collection">["data"] & {
  relatedFooterEntries?: ResolvedRelated[];
};

const {
  title,
  descriptionMd,
  date,
  subtext,
  heroImage,
  media,
  link,
  shouldIframe,
  movieUrl,
  movieEmbed,
  materials,
  imageDescriptions,
  mediaMetadata,
  parentCategory,
  relatedFooterEntries = [],
  descriptionFooterMd,
  related,
} = Astro.props;

const markedOptions = { breaks: true, gfm: true };

// Convert any single \n that isn't preceded by two spaces into \n\n
const normalizedDescription = descriptionMd
  ? descriptionMd.replace(/(?<!  )\n&nbsp;/g, "\n\n")
  : "";

// Parse manual footer markdown if present
const manualFooterParsed = descriptionFooterMd
  ? await marked.parse(
      descriptionFooterMd.trim().replace(/(?<!  )\n&nbsp;/g, "\n\n"),
      markedOptions
    )
  : "";

// Category display order for the auto-generated footer
const categoryOrder = [
  "Exhibition",
  "Press",
  "Speaking, Workshops, Teaching",
  "Fellowships, Residencies, Awards",
  "Project",
];

const headingOverrides: Record<string, string> = {
  "Exhibition": "Exhibition History",
  "Fellowships, Residencies, Awards": "Awards & Fellowships",
  "Project": "Related Projects",
};

// Group footer entries by parentCategory, sorted by date descending within each group
function buildFooterSections(entries: ResolvedRelated[]) {
  const sections: Array<{ heading: string; category: string; items: ResolvedRelated[] }> = [];
  const categorized = new Set<string>();

  function sortByDate(items: ResolvedRelated[]) {
    return items.sort((a, b) => {
      const dateA = a.date ? new Date(a.date).getTime() : 0;
      const dateB = b.date ? new Date(b.date).getTime() : 0;
      return dateB - dateA;
    });
  }

  for (const category of categoryOrder) {
    const items = sortByDate(entries.filter((e) => e.parentCategory === category));
    if (items.length > 0) {
      sections.push({ heading: headingOverrides[category] || category, category, items });
      categorized.add(category);
    }
  }

  // Catch-all for entries with categories not in categoryOrder
  const remaining = entries.filter((e) => !categorized.has(e.parentCategory || ""));
  if (remaining.length > 0) {
    sections.push({
      heading: "Related",
      category: "Related",
      items: sortByDate(remaining),
    });
  }

  return sections;
}

function formatCompactDate(d: Date): string {
  return d.toLocaleDateString("en-us", { month: "short", year: "numeric" });
}

function formatDateRange(item: ResolvedRelated, category: string): string {
  if (!item.date) return "";
  const start = new Date(item.date);
  if (category === "Exhibition" && item.endDate) {
    const end = new Date(item.endDate);
    // Same month+year: just show once
    if (start.getMonth() === end.getMonth() && start.getFullYear() === end.getFullYear()) {
      return formatCompactDate(start);
    }
    return `${formatCompactDate(start)}–${formatCompactDate(end)}`;
  }
  // Exhibitions without end date and workshops/teaching: just start
  if (category === "Exhibition" || category === "Speaking, Workshops, Teaching") {
    return formatCompactDate(start);
  }
  return "";
}

function formatFooterItem(item: ResolvedRelated, category: string): string {
  const shouldLinkInternal = Boolean(item.descriptionMd);
  const href = shouldLinkInternal ? `/creation/${item.id}` : (item.link || "");
  const forthcomingPrefix = item.forthcoming ? "<em>(forthcoming)</em> " : "";
  const linkText = item.title;
  const institutionStr = item.institution?.length ? item.institution.join(", ") : "";
  const locationStr = item.location || "";
  const dateStr = formatDateRange(item, category);

  const datePrefix = dateStr
    ? `<span class="related-date">[${dateStr}]</span> `
    : "";

  const titleHtml = href
    ? `<a href="${href}"><strong>${linkText}</strong></a>`
    : `<strong>${linkText}</strong>`;

  let metaParts = "";
  if (institutionStr) {
    metaParts += `<span class="related-institution"><strong>${institutionStr}</strong></span>`;
  }
  if (locationStr) {
    metaParts += `<span class="related-location">${locationStr}</span>`;
  }

  return `<li>${datePrefix}${forthcomingPrefix}${titleHtml}${metaParts}</li>`;
}

const footerSections = buildFooterSections(relatedFooterEntries);

let autoFooterHtml = "";
for (const section of footerSections) {
  autoFooterHtml += `<p><strong>${section.heading}</strong></p>`;
  autoFooterHtml += `<ul>${section.items.map((item) => formatFooterItem(item, section.category)).join("")}</ul>`;
}

// Combine manual footer (if any) with auto-generated footer
const descriptionFooterParsed = [manualFooterParsed, autoFooterHtml]
  .filter(Boolean)
  .join("");

const transformedMovieUrl = movieUrl
  ? maybeTransformImgixUrl(movieUrl, {
      auto: "format,compress",
      fit: "max",
      w: "2000",
      h: "2000",
    })
  : movieUrl;
const transformedHeroImage = heroImage
  ? maybeTransformImgixUrl(heroImage, {
      auto: "format,compress",
      fit: "max",
      w: "2000",
      h: "2000",
    })
  : heroImage;
const mediaTransformed = media.map((item) => {
  return maybeTransformImgixUrl(item, {
    auto: "format,compress",
    fit: "max",
    w: "2000",
    h: "2000",
  });
});

const style = {
  "--aura-color": stringToColor(title),
  "--aura-color-transparent": stringToColor(title, {
    alpha: 0.3,
  }),
};

// Organize media - all media including movieUrl if present
const allMediaSources = movieUrl ? [transformedMovieUrl] : [];
allMediaSources.push(...mediaTransformed);

const allDescriptions = movieUrl ? [""] : [];
allDescriptions.push(...(imageDescriptions || []));

const allMetadata = movieUrl ? ["video"] : [];
allMetadata.push(...(mediaMetadata || []));

// Helper function to extract domain from URL
function getDomainFromUrl(url: string): string {
  try {
    const urlObj = new URL(url);
    return urlObj.hostname.replace("www.", "");
  } catch {
    return url;
  }
}

const linkDomain = link ? getDomainFromUrl(link) : "";

// --- Interleaved text/media sections ---
// Curated mode: a line like `[media: 2, 4-5]` in descriptionMd pulls those
// items (1-based indices into `media`, ignoring movieUrl) out of the trailing
// gallery and renders them at that point in the text.
// Auto mode (no markers): remaining gallery items are interleaved between
// every couple of paragraphs instead of all dumped at the end.

// movieUrl is prepended to allMediaSources, shifting authored media indices
const mediaIndexOffset = movieUrl ? 1 : 0;
// Hero shows up to 3 items; auto mode only intersperses items beyond those
const HERO_RESERVED = 3;
const AUTO_PARAGRAPHS_PER_SECTION = 2;
const AUTO_IMAGES_PER_BREAK = 2;

// Parses "2, 4-6" into allMediaSources indices
function parseMarkerSpec(spec: string): number[] {
  const indices: number[] = [];
  for (const token of spec.split(",")) {
    const trimmed = token.trim();
    const range = trimmed.match(/^(\d+)\s*-\s*(\d+)$/);
    if (range) {
      for (let i = Number(range[1]); i <= Number(range[2]); i++) {
        indices.push(i);
      }
    } else if (/^\d+$/.test(trimmed)) {
      indices.push(Number(trimmed));
    }
  }
  return indices
    .map((oneBased) => oneBased - 1 + mediaIndexOffset)
    .filter((i) => i >= 0 && i < allMediaSources.length);
}

interface DescriptionSection {
  html: string;
  mediaIndices: number[];
}

const sections: DescriptionSection[] = [];
// split() with a capture group alternates [text, spec, text, spec, ..., text]
const markerParts = normalizedDescription.split(
  /^\s*\[media:\s*([\d\s,-]+)\]\s*$/m
);

if (markerParts.length > 1) {
  for (let i = 1; i <= markerParts.length; i += 2) {
    const text = markerParts[i - 1].trim();
    const spec = markerParts[i];
    sections.push({
      html: text ? await marked.parse(text, markedOptions) : "",
      mediaIndices: spec ? parseMarkerSpec(spec) : [],
    });
  }
} else if (normalizedDescription.trim()) {
  const paragraphs = normalizedDescription
    .split(/\n{2,}/)
    .map((p) => p.trim())
    .filter(Boolean);
  let nextMediaIdx = HERO_RESERVED;
  for (let p = 0; p < paragraphs.length; p += AUTO_PARAGRAPHS_PER_SECTION) {
    const group = paragraphs
      .slice(p, p + AUTO_PARAGRAPHS_PER_SECTION)
      .join("\n\n");
    const isLastGroup = p + AUTO_PARAGRAPHS_PER_SECTION >= paragraphs.length;
    const mediaIndices: number[] = [];
    // No break after the final paragraphs — leftovers flow in the tail gallery
    if (!isLastGroup) {
      while (
        mediaIndices.length < AUTO_IMAGES_PER_BREAK &&
        nextMediaIdx < allMediaSources.length
      ) {
        mediaIndices.push(nextMediaIdx++);
      }
    }
    sections.push({
      html: await marked.parse(group, markedOptions),
      mediaIndices,
    });
  }
}

// Items placed within sections; everything else stays in hero + tail gallery,
// which share the responsive nth-child show/hide pairing
const referencedIndices = new Set(sections.flatMap((s) => s.mediaIndices));
const galleryItems = allMediaSources
  .map((src, i) => ({
    src,
    description: allDescriptions[i] || "",
    type: allMetadata[i],
  }))
  .filter((_, i) => !referencedIndices.has(i));
---

<BaseLayout title={title} description={subtext} image={heroImage}>
  <main class="creationDetail editorial">
    <article>
      <!-- Desktop Editorial Layout -->
      <div class="desktop-layout">
        <!-- Title and Metadata Row -->
        <div>
          <div class="title-metadata-row">
            <h1 class="title-sentence">
              <>
                <b class="creation-title">{title}</b>
                {subtext ? ` is ${subtext}` : ""}
              </>
            </h1>
            <!-- Metadata Sidebar -->
            <div class="metadata-sidebar">
              {
                date && (
                  <div class="category">
                    {/* <!-- TODO: make this clickable and link to this filtered in /creation -->      */}
                    <span class="date">{parentCategory}</span> |{" "}
                    <span class="date">
                      <FormattedDate date={date} />
                    </span>
                  </div>
                )
              }
              <!-- TODO: add link section for other links-->
              {
                link && (
                  <div class="link">
                    <a href={link}>visit {linkDomain}</a>
                  </div>
                )
              }
              {materials && <div class="materials">Materials: {materials}</div>}
            </div>
          </div>
          <!-- Hero Row -->
          <div class="hero-row" style={style}>
            {
              shouldIframe ? (
                <div class="iframeWrapper">
                  <iframe src={link} />
                  <div>
                    window into <a href={link}>{link}</a>
                  </div>
                </div>
              ) : movieEmbed ? (
                <iframe class="movieEmbed" src={movieEmbed} />
              ) : (
                galleryItems.slice(0, 4).map((item) => (
                  <div class="media-item" key={item.src}>
                    <ImageOrVideo
                      client:only="react"
                      className="medium-masonry"
                      src={item.src}
                      type={item.type}
                    />

                    {item.description && (
                      <p class="descriptionText">{item.description}</p>
                    )}
                  </div>
                ))
              )
            }
          </div>
          <!-- Interleaved Description + Media Sections -->
          {
            sections.map((section, i) => (
              <>
                {(section.html || (i === 0 && descriptionFooterParsed)) && (
                  <div
                    class={`descriptions${i === 0 ? "" : " descriptions-continued"}`}
                  >
                    <div class="description-columns">
                      {section.html && <div set:html={section.html} />}
                    </div>
                    {i === 0 && descriptionFooterParsed && (
                      <div
                        class="description-footer description-footer-sidebar meta small"
                        set:html={descriptionFooterParsed}
                      />
                    )}
                  </div>
                )}
                {section.mediaIndices.length > 0 && (
                  <div class="section-media">
                    <CreationDetailImages
                      client:only="react"
                      images={section.mediaIndices.map(
                        (idx) => allMediaSources[idx]
                      )}
                      descriptions={section.mediaIndices.map(
                        (idx) => allDescriptions[idx] || ""
                      )}
                      metadata={section.mediaIndices.map(
                        (idx) => allMetadata[idx]
                      )}
                      renderSingle
                    />
                  </div>
                )}
              </>
            ))
          }
          {
            // On stacked layouts the sidebar footer would interrupt the text
            // after the first section, so it renders at the end instead
            sections.length > 0 && descriptionFooterParsed && (
              <div
                class="description-footer description-footer-stacked meta small"
                set:html={descriptionFooterParsed}
              />
            )
          }
          {
            sections.length === 0 && descriptionFooterParsed && (
              <div class="descriptions">
                <div class="description-columns" />
                <div
                  class="description-footer meta small"
                  set:html={descriptionFooterParsed}
                />
              </div>
            )
          }
        </div>

        <!-- Flow Images -->
        <div class="flow-images">
          <CreationDetailImages
            images={galleryItems.map((item) => item.src)}
            descriptions={galleryItems.map((item) => item.description)}
            client:only="react"
            metadata={galleryItems.map((item) => item.type)}
          />
        </div>

      </div>
    </article>
  </main>
  <script src="https://player.vimeo.com/api/player.js"></script>
</BaseLayout>
